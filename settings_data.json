/* ============================================================
   VIRALCARTS — NEON CYBERPUNK THEME
   Matching: dark navy/black bg · cyan/purple neon · glitch logo
   Font: Barlow Condensed (display) · Barlow (body)
   ============================================================ */

:root {
  --cyan:        #00E5FF;
  --purple:      #A855F7;
  --purple-deep: #7C3AED;
  --blue-dark:   #0D0D2B;
  --blue-mid:    #111133;
  --blue-card:   #0F0F2A;
  --navy:        #070718;
  --white:       #FFFFFF;
  --white-60:    rgba(255,255,255,0.6);
  --white-30:    rgba(255,255,255,0.3);
  --white-10:    rgba(255,255,255,0.1);
  --white-06:    rgba(255,255,255,0.06);
  --orange:      #FF4D00;
  --yellow:      #FFD600;
  --green:       #00FF88;
  --red-live:    #FF3B3B;

  --font-display: 'Barlow Condensed', sans-serif;
  --font-body:    'Barlow', sans-serif;

  --radius-sm:  6px;
  --radius-md:  12px;
  --radius-lg:  20px;
  --radius-pill:999px;

  --glow-cyan:   0 0 20px rgba(0,229,255,0.5);
  --glow-purple: 0 0 20px rgba(168,85,247,0.5);
  --transition:  0.25s cubic-bezier(0.4,0,0.2,1);
}

/* ── RESET ──────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:var(--font-body);
  background:var(--navy);
  color:var(--white);
  line-height:1.5;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
::selection{background:var(--cyan);color:var(--navy)}
img{max-width:100%;display:block}
a{text-decoration:none;color:inherit}
ul{list-style:none}
button,input{font-family:inherit}

/* ── LAYOUT ─────────────────────────────────────────────── */
.container{max-width:1280px;margin:0 auto;padding:0 1.25rem}

/* ── HEADER ─────────────────────────────────────────────── */
.site-header{
  position:fixed;top:0;left:0;right:0;
  z-index:200;
  padding:.9rem 1.25rem;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(7,7,24,0.85);
  backdrop-filter:blur(16px);
  -webkit-backdrop-filter:blur(16px);
  border-bottom:1px solid rgba(0,229,255,0.08);
  transition:background var(--transition);
}
.header-left{display:flex;align-items:center;gap:.75rem}

/* Hamburger */
.hamburger-btn{
  background:none;border:none;cursor:pointer;
  display:flex;flex-direction:column;gap:5px;padding:4px;
}
.hamburger-btn span{
  display:block;width:22px;height:2px;
  background:var(--white);
  transition:background var(--transition);
}
.hamburger-btn:hover span{background:var(--cyan)}

/* Logo */
.site-logo{
  display:flex;align-items:center;gap:.5rem;
  font-family:var(--font-display);
  font-weight:900;font-size:1.15rem;
  letter-spacing:.05em;text-transform:uppercase;
}
.logo-icon{
  width:32px;height:32px;
  background:var(--purple);
  border-radius:var(--radius-sm);
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;
  box-shadow:var(--glow-purple);
}
.logo-text{
  background:linear-gradient(135deg,var(--cyan),var(--purple));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}

/* Header right icons */
.header-right{display:flex;align-items:center;gap:.5rem}
.hdr-icon{
  background:none;border:none;color:var(--white);
  cursor:pointer;padding:.4rem;font-size:1.1rem;
  transition:color var(--transition);
  position:relative;
  display:flex;align-items:center;
}
.hdr-icon:hover{color:var(--cyan)}
.cart-dot{
  position:absolute;top:-1px;right:-1px;
  width:8px;height:8px;
  background:var(--cyan);border-radius:50%;
  box-shadow:var(--glow-cyan);
}

/* ── MOBILE MENU ────────────────────────────────────────── */
.mobile-menu{
  position:fixed;inset:0;
  background:var(--navy);
  z-index:400;
  display:flex;flex-direction:column;
  padding:2rem 1.5rem;
  transform:translateX(-100%);
  transition:transform .35s cubic-bezier(.4,0,.2,1);
}
.mobile-menu.open{transform:translateX(0)}
.mobile-menu-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:3rem}
.mobile-close{background:none;border:none;color:var(--white);font-size:1.8rem;cursor:pointer}
.mobile-nav{display:flex;flex-direction:column;gap:.5rem}
.mobile-nav-link{
  font-family:var(--font-display);
  font-size:2.8rem;font-weight:900;
  letter-spacing:-.01em;text-transform:uppercase;
  color:var(--white);
  border-bottom:1px solid var(--white-06);
  padding:.6rem 0;
  transition:color var(--transition);
}
.mobile-nav-link:hover{color:var(--cyan)}

/* ── OVERLAY ─────────────────────────────────────────────── */
.overlay{
  position:fixed;inset:0;
  background:rgba(0,0,0,.75);
  z-index:300;
  opacity:0;pointer-events:none;
  transition:opacity var(--transition);
}
.overlay.show{opacity:1;pointer-events:all}

/* ── HERO ────────────────────────────────────────────────── */
.hero{
  min-height:100vh;
  display:flex;align-items:stretch;
  flex-direction:column;
  position:relative;
  overflow:hidden;
  padding-top:64px;
}

/* Hero background */
.hero-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 60% at 60% 40%, rgba(88,28,135,.55) 0%, transparent 65%),
    radial-gradient(ellipse 50% 50% at 20% 70%, rgba(0,229,255,.12) 0%, transparent 60%),
    linear-gradient(180deg, #0D0D2B 0%, #070718 100%);
}
.hero-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(0,229,255,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,229,255,.04) 1px, transparent 1px);
  background-size:40px 40px;
}
.hero-scanlines{
  position:absolute;inset:0;
  background:repeating-linear-gradient(
    0deg,
    rgba(0,0,0,0) 0px,
    rgba(0,0,0,0) 2px,
    rgba(0,0,0,.08) 2px,
    rgba(0,0,0,.08) 4px
  );
  pointer-events:none;
}

.hero-inner{
  position:relative;z-index:2;
  flex:1;display:flex;flex-direction:column;
  max-width:480px;
  padding:2.5rem 1.25rem 2rem;
}

/* Trending badge */
.hero-badge{
  display:inline-flex;align-items:center;gap:.4rem;
  background:rgba(168,85,247,.2);
  border:1px solid rgba(168,85,247,.4);
  color:var(--purple);
  font-family:var(--font-display);
  font-size:.7rem;font-weight:700;
  letter-spacing:.18em;text-transform:uppercase;
  padding:.35rem .9rem;
  border-radius:var(--radius-pill);
  margin-bottom:1.2rem;
  width:fit-content;
}
.badge-dot{
  width:6px;height:6px;
  background:var(--purple);border-radius:50%;
  box-shadow:var(--glow-purple);
  animation:blink 1.5s ease-in-out infinite;
}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* Hero title */
.hero-title{
  font-family:var(--font-display);
  font-size:clamp(3.2rem,12vw,5.5rem);
  font-weight:900;
  line-height:.95;
  letter-spacing:-.01em;
  text-transform:uppercase;
  margin-bottom:1rem;
}
.hero-title .line-white{color:var(--white)}
.hero-title .line-cyan{color:var(--cyan);text-shadow:var(--glow-cyan)}

.hero-desc{
  font-size:.95rem;
  color:var(--white-60);
  line-height:1.6;
  margin-bottom:1.8rem;
  max-width:320px;
}

/* CTA button */
.btn-neon{
  display:inline-flex;align-items:center;gap:.5rem;
  font-family:var(--font-display);
  font-weight:800;font-size:1rem;
  letter-spacing:.1em;text-transform:uppercase;
  background:var(--purple-deep);
  color:var(--white);
  padding:.85rem 2rem;
  border-radius:var(--radius-sm);
  border:none;cursor:pointer;
  transition:all var(--transition);
  position:relative;overflow:hidden;
  box-shadow:0 0 30px rgba(124,58,237,.4);
}
.btn-neon::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.1),transparent);
  transform:translateX(-100%);
  transition:transform .5s;
}
.btn-neon:hover::before{transform:translateX(100%)}
.btn-neon:hover{box-shadow:0 0 50px rgba(124,58,237,.7);transform:translateY(-2px)}

/* Hero product image card */
.hero-product-card{
  position:relative;z-index:2;
  margin:0 1.25rem 2.5rem;
  border-radius:var(--radius-lg);
  overflow:hidden;
  border:1px solid rgba(0,229,255,.15);
  box-shadow:0 0 40px rgba(0,229,255,.1), 0 20px 60px rgba(0,0,0,.6);
  aspect-ratio:4/3;
  background:var(--blue-card);
}
.hero-product-card img{
  width:100%;height:100%;
  object-fit:cover;
}
.hero-live-badge{
  position:absolute;bottom:1rem;left:1rem;
  display:flex;align-items:center;gap:.4rem;
  background:rgba(0,0,0,.75);
  backdrop-filter:blur(8px);
  border:1px solid var(--white-10);
  border-radius:var(--radius-sm);
  padding:.4rem .75rem;
}
.live-dot{
  width:6px;height:6px;
  background:var(--red-live);border-radius:50%;
  box-shadow:0 0 8px var(--red-live);
  animation:blink 1s ease-in-out infinite;
}
.live-label{font-size:.6rem;color:var(--white-60);text-transform:uppercase;letter-spacing:.1em}
.live-count{font-family:var(--font-display);font-size:1.1rem;font-weight:900;color:var(--white)}

/* ── SECTION: HITS ──────────────────────────────────────── */
.hits-section{
  padding:2.5rem 0 4rem;
  background:var(--navy);
}
.hits-header{
  padding:0 1.25rem 1.5rem;
  display:flex;align-items:baseline;gap:.75rem;
}
.hits-title{
  font-family:var(--font-display);
  font-size:2.2rem;font-weight:900;
  letter-spacing:-.02em;text-transform:uppercase;
  color:var(--white);
}
.hits-underline{
  display:block;
  height:3px;width:100%;
  background:linear-gradient(90deg,var(--cyan),var(--purple));
  margin-top:.2rem;
  border-radius:2px;
}

/* Product card — matches mockup */
.product-card-v3{
  position:relative;
  background:var(--blue-card);
  border:1px solid var(--white-06);
  border-radius:var(--radius-md);
  overflow:hidden;
  margin:0 1.25rem 1rem;
  display:flex;
  align-items:stretch;
  min-height:120px;
  transition:transform var(--transition),border-color var(--transition),box-shadow var(--transition);
  cursor:pointer;
}
.product-card-v3:hover{
  transform:translateY(-3px);
  border-color:rgba(0,229,255,.25);
  box-shadow:0 8px 32px rgba(0,229,255,.1);
}

/* Full-bleed hero card (first card) */
.product-card-v3.hero-card{
  flex-direction:column;
  min-height:280px;
}
.product-card-v3.hero-card .pcard-image{
  width:100%;
  flex-shrink:0;
  height:200px;
  aspect-ratio:unset;
}
.product-card-v3.hero-card .pcard-info{
  padding:1rem 1.1rem 1.2rem;
}

/* Standard horizontal card */
.pcard-image{
  width:110px;
  flex-shrink:0;
  position:relative;
  overflow:hidden;
  background:var(--blue-mid);
}
.pcard-image img{
  width:100%;height:100%;
  object-fit:cover;
  transition:transform .5s ease;
}
.product-card-v3:hover .pcard-image img{transform:scale(1.06)}

.pcard-info{
  flex:1;
  padding:.9rem 1rem;
  display:flex;flex-direction:column;justify-content:center;
  position:relative;
}

/* Badges */
.pcard-badges{display:flex;gap:.4rem;margin-bottom:.4rem;flex-wrap:wrap}
.pbadge{
  font-family:var(--font-display);
  font-size:.6rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;
  padding:.2rem .55rem;
  border-radius:var(--radius-pill);
}
.pbadge-bestseller{background:rgba(0,229,255,.15);color:var(--cyan);border:1px solid rgba(0,229,255,.3)}
.pbadge-tiktok    {background:rgba(255,0,80,.15);color:#FF0050;border:1px solid rgba(255,0,80,.3)}
.pbadge-staffpick {background:rgba(168,85,247,.15);color:var(--purple);border:1px solid rgba(168,85,247,.3)}
.pbadge-trending  {background:rgba(255,214,0,.12);color:var(--yellow);border:1px solid rgba(255,214,0,.3)}
.pbadge-highdemand{background:rgba(255,77,0,.12);color:var(--orange);border:1px solid rgba(255,77,0,.3)}

.pcard-views{
  display:flex;align-items:center;gap:.3rem;
  font-size:.7rem;color:var(--white-30);
  margin-bottom:.3rem;
}
.pcard-views svg{width:12px;height:12px;opacity:.5}

.pcard-title{
  font-family:var(--font-display);
  font-size:1.25rem;font-weight:900;
  letter-spacing:-.01em;text-transform:uppercase;
  line-height:1.05;
  margin-bottom:.4rem;
  color:var(--white);
}
.product-card-v3.hero-card .pcard-title{font-size:1.6rem}

.pcard-price{
  font-family:var(--font-display);
  font-size:1.1rem;font-weight:800;
  color:var(--cyan);
}
.pcard-compare{
  font-size:.8rem;
  color:var(--white-30);
  text-decoration:line-through;
  margin-left:.4rem;
}

.pcard-cta{
  font-family:var(--font-display);
  font-size:.75rem;font-weight:700;
  letter-spacing:.08em;text-transform:uppercase;
  color:var(--purple);
  display:flex;align-items:center;gap:.3rem;
  margin-top:.5rem;
  transition:color var(--transition);
}
.product-card-v3:hover .pcard-cta{color:var(--cyan)}

/* Cart button (right side) */
.pcard-cart-btn{
  position:absolute;bottom:.9rem;right:.9rem;
  width:36px;height:36px;
  background:var(--white-06);
  border:1px solid var(--white-10);
  border-radius:var(--radius-sm);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:1rem;
  transition:all var(--transition);
  color:var(--white);
}
.pcard-cart-btn:hover{background:var(--purple);border-color:var(--purple);box-shadow:var(--glow-purple)}

/* Demand bar */
.demand-bar{
  position:absolute;bottom:0;left:0;right:0;
  height:2px;
  background:linear-gradient(90deg,var(--cyan),var(--purple));
}

/* ── DESKTOP GRID MODE ─────────────────────────────────── */
@media (min-width:768px){
  .site-header{padding:.9rem 2rem}
  .hero-inner{max-width:600px;padding:3rem 2rem 2.5rem}
  .hero-product-card{margin:0 2rem 2rem;aspect-ratio:16/7}
  .product-card-v3{margin:0 0 1rem}
  .hits-header{padding:0 0 1.5rem}
  .hits-grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:1rem;
  }
  .product-card-v3.hero-card{
    grid-column:1/-1;
    flex-direction:row;
    min-height:220px;
  }
  .product-card-v3.hero-card .pcard-image{
    width:45%;height:auto;
  }
  .product-card-v3.hero-card .pcard-title{font-size:2rem}
  .hits-section{padding:4rem 0 5rem}
}

@media (min-width:1100px){
  .hero{flex-direction:row;min-height:100vh}
  .hero-inner{max-width:540px;padding:7rem 3rem 3rem 2rem;flex-shrink:0}
  .hero-product-card{
    flex:1;margin:5rem 2rem 2rem 0;
    aspect-ratio:unset;
    border-radius:var(--radius-lg);
    align-self:center;
    height:calc(100vh - 8rem);
  }
  .hits-grid{grid-template-columns:repeat(3,1fr)}
  .product-card-v3.hero-card{grid-column:1/-1}
}

/* ── CART DRAWER ─────────────────────────────────────────── */
.cart-drawer{
  position:fixed;top:0;right:-100%;
  width:min(400px,100vw);height:100vh;
  background:var(--blue-mid);
  border-left:1px solid var(--white-10);
  z-index:500;
  display:flex;flex-direction:column;
  transition:right .35s cubic-bezier(.4,0,.2,1);
}
.cart-drawer.open{right:0}
.cart-hdr{
  display:flex;align-items:center;justify-content:space-between;
  padding:1.25rem 1.5rem;
  border-bottom:1px solid var(--white-10);
}
.cart-hdr h3{
  font-family:var(--font-display);
  font-size:1.4rem;font-weight:900;text-transform:uppercase;
  letter-spacing:.05em;
}
.cart-body{flex:1;overflow-y:auto;padding:1.25rem 1.5rem}
.cart-empty{text-align:center;padding:4rem 1rem;color:var(--white-30)}
.cart-item{
  display:flex;gap:1rem;
  padding:1rem 0;
  border-bottom:1px solid var(--white-06);
}
.cart-item-img{width:68px;height:68px;object-fit:cover;border-radius:var(--radius-sm);flex-shrink:0}
.cart-item-name{font-size:.875rem;font-weight:600;margin-bottom:.2rem}
.cart-item-price{font-family:var(--font-display);font-weight:800;font-size:1rem;color:var(--cyan)}
.cart-foot{
  padding:1.25rem 1.5rem;
  border-top:1px solid var(--white-10);
}
.cart-subtotal{
  display:flex;justify-content:space-between;
  font-family:var(--font-display);font-weight:800;font-size:1.1rem;
  margin-bottom:1rem;
}
.cart-subtotal span:last-child{color:var(--cyan)}
.btn-checkout{
  width:100%;
  font-family:var(--font-display);
  font-size:1rem;font-weight:900;letter-spacing:.1em;text-transform:uppercase;
  background:linear-gradient(135deg,var(--purple-deep),var(--cyan));
  color:var(--white);
  padding:1rem;
  border:none;border-radius:var(--radius-sm);
  cursor:pointer;
  transition:opacity var(--transition);
  display:flex;align-items:center;justify-content:center;gap:.5rem;
}
.btn-checkout:hover{opacity:.9}

/* ── FOOTER ─────────────────────────────────────────────── */
.site-footer{
  background:#000;
  border-top:1px solid var(--white-06);
  padding:3.5rem 1.25rem 2rem;
}
.footer-logo{
  display:flex;align-items:center;gap:.5rem;
  font-family:var(--font-display);font-size:1.3rem;font-weight:900;
  letter-spacing:.05em;text-transform:uppercase;
  margin-bottom:1rem;
}
.footer-desc{font-size:.8rem;color:var(--white-30);line-height:1.7;margin-bottom:1.5rem;max-width:280px}
.footer-cols{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:2rem;margin-bottom:2.5rem;
}
@media (min-width:768px){
  .site-footer{padding:4rem 2rem 2.5rem}
  .footer-cols{grid-template-columns:2fr 1fr 1fr 1fr}
}
.footer-col-title{
  font-family:var(--font-display);
  font-size:.8rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;
  color:var(--white-60);margin-bottom:1rem;
}
.footer-links{display:flex;flex-direction:column;gap:.6rem}
.footer-link{font-size:.82rem;color:var(--white-30);transition:color var(--transition)}
.footer-link:hover{color:var(--cyan)}
.footer-bottom{
  display:flex;align-items:center;justify-content:space-between;
  padding-top:1.5rem;
  border-top:1px solid var(--white-06);
  flex-wrap:wrap;gap:1rem;
}
.footer-copy{font-size:.72rem;color:rgba(255,255,255,.15)}
.footer-payments{display:flex;gap:.5rem;opacity:.25;filter:grayscale(1)}
.pay-badge{
  font-size:.6rem;font-weight:700;
  background:var(--white-10);
  border-radius:3px;padding:.25rem .55rem;
  color:var(--white);
}

/* ── ANIMATIONS ─────────────────────────────────────────── */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.anim-up{opacity:0;transform:translateY(20px);transition:opacity .5s ease,transform .5s ease}
.anim-up.in{opacity:1;transform:translateY(0)}

/* ── SCROLLBAR ──────────────────────────────────────────── */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--navy)}
::-webkit-scrollbar-thumb{background:var(--purple);border-radius:2px}

/* ── LOGO IMAGE ─────────────────────────────────────────── */
.logo-img {
  height: 38px;
  width: auto;
  object-fit: contain;
  display: block;
  /* preserve the neon glow from the original logo */
  filter: drop-shadow(0 0 8px rgba(0,229,255,0.5)) drop-shadow(0 0 16px rgba(168,85,247,0.4));
  transition: filter 0.3s ease;
}
.logo-img:hover {
  filter: drop-shadow(0 0 14px rgba(0,229,255,0.9)) drop-shadow(0 0 28px rgba(168,85,247,0.7));
}
.logo-img-lg {
  height: 56px;
}

/* Footer logo image */
.footer-logo-img {
  height: 52px;
  width: auto;
  object-fit: contain;
  filter: drop-shadow(0 0 8px rgba(0,229,255,0.4)) drop-shadow(0 0 16px rgba(168,85,247,0.3));
  margin-bottom: 1rem;
  display: block;
}
